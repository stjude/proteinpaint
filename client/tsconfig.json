{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "target": "es2017",
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler", // to skip errors related to import of types from ts files
    "customConditions": ["sjpp/dev"]
  },
  "include": ["./**/*.ts"],
  "exclude": [
    "./dist/**/*"
  ]
}