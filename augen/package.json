{
  "name": "@sjcrh/augen",
  "version": "2.190.0",
  "description": "Automatic generator of server routes, unit tests, and API documentation",
  "type": "module",
  "main": "src/augen.js",
  "bin": "cli.js",
  "exports": {
    ".": "./src/augen.js",
    "./dev": "./src/dev.js"
  },
  "imports": {
    "#src/*": "./src/*",
    "#public/*": "./public/*"
  },
  "scripts": {
    "predev": "tsx test/prep.js",
    "dev": "npm run doc && tsx watch test/app.js",
    "pretest": "tsx src/test/toyApp/prep.js",
    "test": "c8 tsx src/test/runSpecs.js",
    "spec:coverage": "tsx src/test/relevant.js -p",
    "doc": "./build.sh test/routes test/types test/checkers public/docs"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.25.9",
    "express": "^4.17.1",
    "node-polyfill-webpack-plugin": "^4.0.0",
    "tape": "^5.2.2",
    "tsx": "^4.7.1"
  },
  "files": [
    "src",
    "!src/test",
    "build.sh",
    "cli.js",
    "readme.sh",
    "webpack.config.cjs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stjude/proteinpaint"
  }
}
