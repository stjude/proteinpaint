{
  "name": "@sjcrh/proteinpaint-types",
  "version": "2.189.0",
  "type": "module",
  "description": "Shared type definitions between ProteinPaint server and client code",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "exports": {
    ".": {
      "sjpp/dev": "./src/index.ts",
      "default": "non-prod-only.ts"
    },
    "./routes/*": {
      "sjpp/dev": "./src/routes/*",
      "default": "non-prod-only.ts"
    }
  },
  "imports": {
    "#shared": "@sjcrh/proteinpaint-shared",
    "#shared/devTs": "@sjcrh/proteinpaint-shared/devTs"
  },
  "scripts": {
    "dev": "echo '--- using server/checkers for request payload validation ---'",
    "build": "./build.sh",
    "test": "tsc"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "files": [
    "non-prod-only.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stjude/proteinpaint",
    "directory": "server"
  }
}
