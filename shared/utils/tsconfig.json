{
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": "./",
    "rootDir": "./",
    //"allowJs": true, // TODO: enable later so that consumer code of shared helpers will be type checked
    //"noEmit": true,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "dist",
    "target": "es2019",
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler", // to skip errors related to import of types from ts files
    "customConditions": ["sjpp/dev"]
  },
  "include": ["./constants/*", "./src/*"],
  "exclude": [
    "./node_modules",
    "./dist/**/*",
    "./**/test",
    "../types"
  ]
}
