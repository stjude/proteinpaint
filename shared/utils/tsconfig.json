{
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": "./",
    //"noEmit": true,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "dist",
    "target": "es2019",
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler" // to skip errors related to import of types from ts files
  },
  "include": ["src/*"],
  "exclude": [
    "./node_modules",
    "**/test"
  ]
}
