{
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": "./",
    "rootDir": "./",
    //"noEmit": true,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "dist",
    "target": "es2019",
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler" // to skip errors related to import of types from ts files
  },
  // the order of input dirs is significant:
  // - constants ts files should not have imports, to avoid cyclical dependencies that breaks tsc and bundling startup
  // - shared/types may import type code from @sjcrh/proteinpaint-shared/constants
  // - src/ code is always allowed to import any type definition from shared/types
  "include": ["./constants/*", "./src/*"],
  "exclude": [
    "./node_modules",
    "./dist/**/*",
    "./**/test",
    "../types"
  ]
}
